POI_SERVER_DISABLE_LOGGER=0
POI_SERVER_DB=mongodb://localhost:27017/poi-development
POI_SERVER_PORT=17027
NODE_ENV=development

# Opt-in production-path PostgreSQL e2e coverage (tests/server.postgres.e2e.test.ts).
# Leave unset locally to skip the suite. In CI this must always be set.
# The target database must be local (localhost/127.0.0.1/::1) and its name must contain
# "poi-e2e"; the test suite refuses to run against anything else. Before running the suite,
# apply migrations and create a Data Epoch with:
#   POI_SERVER_DATABASE_URL=$POI_SERVER_POSTGRES_E2E_URL npm run db:migrate
#   POI_SERVER_DATABASE_URL=$POI_SERVER_POSTGRES_E2E_URL npm run db:create-epoch -- 2024-01-01T00:00:00.000Z
# POI_SERVER_POSTGRES_E2E_URL=postgres://postgres:postgres@localhost:5432/poi-e2e
