POI_SERVER_DISABLE_LOGGER=0
POI_SERVER_DB=mongodb://localhost:27017/poi-development
POI_SERVER_PORT=17027
NODE_ENV=development

# Opt-in production-path PostgreSQL e2e coverage (tests/server.postgres.e2e.test.ts).
# Leave unset locally to skip the suite. In CI this must always be set.
# The target database must be local (localhost/127.0.0.1/::1) and its name must contain
# "poi-e2e"; the test suite refuses to run against anything else. Before running the suite,
# apply migrations and create a Data Epoch with:
#   POI_SERVER_DATABASE_URL=$POI_SERVER_POSTGRES_E2E_URL npm run db:migrate
#   POI_SERVER_DATABASE_URL=$POI_SERVER_POSTGRES_E2E_URL npm run db:create-epoch -- 2024-01-01T00:00:00.000Z
# POI_SERVER_POSTGRES_E2E_URL=postgres://postgres:postgres@localhost:5432/poi-e2e

# PostgreSQL connection URL used by every PostgreSQL-backed command (server startup, migrations,
# partition maintenance, and the Community Dump publish/cleanup CLI commands below).
# POI_SERVER_DATABASE_URL is preferred; POI_SERVER_DB (above) is kept only as a legacy fallback
# when POI_SERVER_DATABASE_URL is unset. Must use the postgres:// or postgresql:// scheme for any
# PostgreSQL-only command (db:migrate, db:partitions:*, db:dumps:*) -- a mongodb:// URL is rejected.
# SECRET: contains the database password; never commit a real value.
# POI_SERVER_DATABASE_URL=postgresql://user:password@localhost:5432/poi-development

# Cloudflare R2 (or any S3-compatible) object-store configuration for the Community Dump
# publish/cleanup CLI commands (db:dumps:publish, db:dumps:cleanup). All four are required
# whenever those commands run; there is no default bucket or endpoint.
# POI_SERVER_DUMP_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# POI_SERVER_DUMP_R2_BUCKET=community-dumps
# SECRET: never commit a real value.
# POI_SERVER_DUMP_R2_ACCESS_KEY_ID=changeme
# SECRET: never commit a real value.
# POI_SERVER_DUMP_R2_SECRET_ACCESS_KEY=changeme
# Optional; defaults to "auto" (Cloudflare R2's own recommended value).
# POI_SERVER_DUMP_R2_REGION=auto
# Optional; defaults to true (path-style addressing, required by R2 and most S3-compatible
# providers). Set to "false" only for a provider that requires virtual-hosted-style addressing.
# POI_SERVER_DUMP_R2_FORCE_PATH_STYLE=true

# Example offline Community Dump commands (require POI_SERVER_DATABASE_URL to be a postgres:// or
# postgresql:// URL, and all four POI_SERVER_DUMP_R2_* variables above to be set):
#   npm run db:dumps:publish -- 2024-01
#   npm run db:dumps:cleanup -- 42
