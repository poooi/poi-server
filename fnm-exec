#!/bin/bash
set -euo pipefail

export FNM_DIR="${FNM_DIR:-/home/poi/.local/share/fnm}"
FNM_BIN="${FNM_BIN:-$FNM_DIR/fnm}"

if [ ! -x "$FNM_BIN" ]; then
  echo "fnm is required but was not found at $FNM_BIN" >&2
  exit 127
fi

cd /srv/poi
eval "$("$FNM_BIN" env --shell bash)"
"$FNM_BIN" use

exec "$@"
